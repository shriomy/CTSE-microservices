              "raw": "{\n  \"name\": \"Notebook A4\",\n  \"description\": \"Premium quality spiral notebook with 200 pages\",\n  \"price\": 299.99,\n  \"imageUrl\": \"https://example.com/notebook-a4.jpg\",\n  \"availability\": true\n}"
            },
            "url": {
              "raw": "http://localhost:8083/api/products/admin/create",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["api", "products", "admin", "create"]
            }
          }
        },
        {
          "name": "Update Product (Admin Route)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
