        },
        {
          "name": "User Tries to Delete (Should Fail)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8083/api/products/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["api", "products", "1"]
            }
          }
