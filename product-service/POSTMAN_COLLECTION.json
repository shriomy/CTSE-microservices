              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 349.99,\n  \"availability\": true\n}"
            },
            "url": {
              "raw": "http://localhost:8083/api/products/admin/update/2",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["api", "products", "admin", "update", "2"]
